# Copie este arquivo para .env e preencha com seus dados reais

# ── Banco de dados ──────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=secretariadigital
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_aqui

# ── E-mail (SMTP) ────────────────────────────────────────
# Para Gmail: ative "Senhas de app" em myaccount.google.com/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
SMTP_FROM=Secretaria Digital <seu_email@gmail.com>

# ── URL base (para links de confirmação) ─────────────────
BASE_URL=http://127.0.0.1:8001

# ── WhatsApp (Evolution API) ──────────────────────────────
# Instale: https://doc.evolution-api.com
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_aqui
EVOLUTION_INSTANCE=secretaria

# ── Scheduler ─────────────────────────────────────────────
DEFAULT_LOJA_ID=1

# ── Google Calendar ───────────────────────────────────────
# Arquivo gerado no Google Cloud Console (OAuth 2.0)
GOOGLE_CREDENTIALS_FILE=google_credentials.json
GOOGLE_TOKEN_FILE=google_token.json
GOOGLE_CALENDAR_ID=primary
